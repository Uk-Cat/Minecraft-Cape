{
  "schemaVersion": 1,
  "id": "minecraftcapes",
  "version": "1.0.1",
  "name": "MinecraftCapes",
  "description": "A mod that adds custom capes to Minecraft.",
  "authors": [
    "MinecraftCapes"
  ],
  "license": "LGPL-2.1-only",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.minecraftcapes.fabric.FabricClient"
    ],
    "server": [
      "net.minecraftcapes.fabric.FabricServer"
    ]
  },
  "mixins": [
    "minecraftcapes.mixins.json"
  ],
  "depends": {
